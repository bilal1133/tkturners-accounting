{
  "kind": "collectionType",
  "collectionName": "finance_transaction_lines",
  "info": {
    "singularName": "finance-transaction-line",
    "pluralName": "finance-transaction-lines",
    "displayName": "Finance Transaction Line",
    "description": "Account movement lines"
