      "required": true
    },
    "account_id": {
      "type": "biginteger",
      "required": true
    },
    "direction": {
      "type": "enumeration",
      "enum": ["IN", "OUT"],
      "required": true
    },
    "amount_minor": {
      "type": "biginteger",
      "required": true
    },
    "currency": {
      "type": "string",
      "required": true
    },
    "line_role": {
      "type": "enumeration",
      "enum": ["PRIMARY", "COUNTERPART"],
      "required": true
    }
  }
}
