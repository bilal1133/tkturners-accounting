{
  "kind": "collectionType",
  "collectionName": "finance_employees",
  "info": {
    "singularName": "finance-employee",
    "pluralName": "finance-employees",
    "displayName": "Finance Employee",
    "description": "Employee payroll master records"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "workspace_id": { "type": "biginteger", "required": true },
    "employee_code": { "type": "string", "required": true },
    "full_name": { "type": "string", "required": true },
    "email": { "type": "email" },
    "join_date": { "type": "date" },
    "status": {
      "type": "enumeration",
      "enum": ["ACTIVE", "INACTIVE"],
      "required": true,
      "default": "ACTIVE"
    },
    "payroll_currency": { "type": "string", "required": true },
    "default_payout_account_id": { "type": "biginteger", "required": true },
    "default_funding_account_id": { "type": "biginteger" },
    "department_id": { "type": "biginteger" },
    "linked_counterparty_id": { "type": "biginteger", "required": true },
    "base_salary_minor": { "type": "biginteger", "required": true, "default": 0 },
    "default_allowances_minor": { "type": "biginteger", "required": true, "default": 0 },
    "default_non_loan_deductions_minor": { "type": "biginteger", "required": true, "default": 0 },
    "notes": { "type": "text" },
    "created_by_user_id": { "type": "biginteger", "required": true }
  }
}
