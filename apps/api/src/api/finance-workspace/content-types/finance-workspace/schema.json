{
  "kind": "collectionType",
  "collectionName": "finance_workspaces",
  "info": {
    "singularName": "finance-workspace",
    "pluralName": "finance-workspaces",
    "displayName": "Finance Workspace",
    "description": "Workspace configuration"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "base_currency": {
      "type": "string",
      "required": true
    },
    "timezone": {
      "type": "string",
      "required": true
    },
    "web_entry_default_status": {
      "type": "enumeration",
      "enum": ["PENDING", "APPROVED"],
      "required": true,
      "default": "APPROVED"
    },
    "allow_self_approval": {
      "type": "boolean",
      "default": true
    }
  }
}
