{
  "kind": "collectionType",
  "collectionName": "finance_payroll_entries",
  "info": {
    "singularName": "finance-payroll-entry",
    "pluralName": "finance-payroll-entries",
    "displayName": "Finance Payroll Entry",
    "description": "Employee-level payroll line in a run"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "workspace_id": { "type": "biginteger", "required": true },
    "payroll_run_id": { "type": "biginteger", "required": true },
    "employee_id": { "type": "biginteger", "required": true },
    "loan_id": { "type": "biginteger" },
    "currency": { "type": "string", "required": true },
    "base_salary_minor": { "type": "biginteger", "required": true, "default": 0 },
    "allowances_minor": { "type": "biginteger", "required": true, "default": 0 },
    "non_loan_deductions_minor": { "type": "biginteger", "required": true, "default": 0 },
    "planned_loan_deduction_minor": { "type": "biginteger", "required": true, "default": 0 },
    "actual_loan_deduction_minor": { "type": "biginteger", "required": true, "default": 0 },
    "net_paid_minor": { "type": "biginteger", "required": true, "default": 0 },
    "status": {
      "type": "enumeration",
      "enum": ["DRAFT", "APPROVED", "PAID"],
      "required": true,
      "default": "DRAFT"
    },
    "salary_expense_transaction_id": { "type": "biginteger" },
    "loan_principal_repayment_transaction_id": { "type": "biginteger" },
    "loan_interest_income_transaction_id": { "type": "biginteger" },
    "payout_from_account_id": { "type": "biginteger" },
    "payout_to_account_id": { "type": "biginteger" },
    "payout_from_amount_minor": { "type": "biginteger" },
    "payout_from_currency": { "type": "string" },
    "payout_to_amount_minor": { "type": "biginteger" },
    "payout_to_currency": { "type": "string" },
    "payout_fx_rate": { "type": "decimal" },
    "payout_transfer_transaction_id": { "type": "biginteger" },
    "payout_transfer_fee_transaction_id": { "type": "biginteger" },
    "payout_additional_fee_total_minor": { "type": "biginteger", "required": true, "default": 0 },
    "payout_additional_fee_count": { "type": "integer", "required": true, "default": 0 }
  }
}
