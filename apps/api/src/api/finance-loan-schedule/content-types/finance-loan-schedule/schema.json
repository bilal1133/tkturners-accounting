{
  "kind": "collectionType",
  "collectionName": "finance_loan_schedules",
  "info": {
    "singularName": "finance-loan-schedule",
    "pluralName": "finance-loan-schedules",
    "displayName": "Finance Loan Schedule",
    "description": "Loan installment schedule and repayments"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "loan_id": { "type": "biginteger", "required": true },
    "installment_no": { "type": "integer", "required": true },
    "due_date": { "type": "date", "required": true },
    "principal_due_minor": { "type": "biginteger", "required": true, "default": 0 },
    "interest_due_minor": { "type": "biginteger", "required": true, "default": 0 },
    "principal_paid_minor": { "type": "biginteger", "required": true, "default": 0 },
    "interest_paid_minor": { "type": "biginteger", "required": true, "default": 0 },
    "status": {
      "type": "enumeration",
      "enum": ["DUE", "PARTIAL", "PAID"],
      "required": true,
      "default": "DUE"
    },
    "linked_payroll_entry_id": { "type": "biginteger" }
  }
}
