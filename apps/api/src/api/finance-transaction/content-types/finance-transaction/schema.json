{
  "kind": "collectionType",
  "collectionName": "finance_transactions",
  "info": {
    "singularName": "finance-transaction",
    "pluralName": "finance-transactions",
    "displayName": "Finance Transaction",
    "description": "Ledger transactions"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "workspace_id": {
      "type": "biginteger",
      "required": true
    },
    "transaction_date": {
      "type": "date",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["INCOME", "EXPENSE", "TRANSFER"],
      "required": true
    },
    "source": {
      "type": "enumeration",
      "enum": ["WEB", "SLACK", "SYSTEM"],
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["PENDING", "APPROVED", "REJECTED"],
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "category_id": {
      "type": "biginteger"
    },
    "counterparty_id": {
      "type": "biginteger"
    },
    "created_by_user_id": {
      "type": "biginteger",
      "required": true
    },
    "approved_by_user_id": {
      "type": "biginteger"
    },
    "approved_at": {
      "type": "datetime"
    },
    "currency": {
      "type": "string",
      "required": true
    },
    "amount_minor": {
      "type": "biginteger",
      "required": true
    },
    "fx_rate_to_base": {
      "type": "decimal"
    },
    "base_amount_minor": {
      "type": "biginteger"
    },
    "metadata_json": {
      "type": "json"
    }
  }
}
