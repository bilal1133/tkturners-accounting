{
  "kind": "collectionType",
  "collectionName": "finance_employee_loans",
  "info": {
    "singularName": "finance-employee-loan",
    "pluralName": "finance-employee-loans",
    "displayName": "Finance Employee Loan",
    "description": "Employee loan master"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "workspace_id": { "type": "biginteger", "required": true },
    "employee_id": { "type": "biginteger", "required": true },
    "currency": { "type": "string", "required": true },
    "principal_minor": { "type": "biginteger", "required": true },
    "annual_interest_bps": { "type": "integer", "required": true, "default": 0 },
    "installment_minor": { "type": "biginteger", "required": true },
    "disbursement_date": { "type": "date" },
    "next_due_date": { "type": "date" },
    "outstanding_principal_minor": { "type": "biginteger", "required": true },
    "outstanding_interest_minor": { "type": "biginteger", "required": true, "default": 0 },
    "status": {
      "type": "enumeration",
      "enum": ["DRAFT", "APPROVED", "ACTIVE", "CLOSED", "CANCELED"],
      "required": true,
      "default": "APPROVED"
    },
    "disbursement_account_id": { "type": "biginteger", "required": true },
    "receivable_control_account_id": { "type": "biginteger", "required": true },
    "disbursement_transaction_id": { "type": "biginteger" },
    "approved_by_user_id": { "type": "biginteger" },
    "approved_at": { "type": "datetime" },
    "created_by_user_id": { "type": "biginteger", "required": true }
  }
}
