{
  "kind": "collectionType",
  "collectionName": "finance_accounts",
  "info": {
    "singularName": "finance-account",
    "pluralName": "finance-accounts",
    "displayName": "Finance Account",
    "description": "Manual ledger accounts"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "workspace_id": {
      "type": "biginteger",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "owner_user_id": {
      "type": "biginteger"
    },
    "currency": {
      "type": "string",
      "required": true
    },
    "opening_balance_minor": {
      "type": "biginteger",
      "required": true,
      "default": 0
    },
    "notes": {
      "type": "text"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "account_kind": {
      "type": "enumeration",
      "enum": ["CASH", "LOAN_RECEIVABLE_CONTROL"],
      "required": true,
      "default": "CASH"
    },
    "is_system": {
      "type": "boolean",
      "default": false
    },
    "created_by_user_id": {
      "type": "biginteger",
      "required": true
    }
  }
}
