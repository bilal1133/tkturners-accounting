{
  "kind": "collectionType",
  "collectionName": "finance_slack_drafts",
  "info": {
    "singularName": "finance-slack-draft",
    "pluralName": "finance-slack-drafts",
    "displayName": "Finance Slack Draft",
    "description": "Slack parser confirmation drafts"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "draft_token": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "workspace_id": {
      "type": "biginteger",
      "required": true
    },
    "slack_team_id": {
      "type": "string"
    },
    "slack_channel_id": {
      "type": "string"
    },
    "slack_user_id": {
      "type": "string"
    },
    "raw_text": {
      "type": "text",
      "required": true
    },
    "parsed_payload_json": {
      "type": "json",
      "required": true
    },
    "confidence": {
      "type": "decimal",
      "required": true,
      "default": 0
    },
    "missing_fields_json": {
      "type": "json",
      "required": true
    },
    "state": {
      "type": "enumeration",
      "enum": ["PENDING", "CONFIRMED", "CANCELED", "EXPIRED"],
      "required": true,
      "default": "PENDING"
    },
    "expires_at": {
      "type": "datetime",
      "required": true
    },
    "created_transaction_id": {
      "type": "biginteger"
    }
  }
}
