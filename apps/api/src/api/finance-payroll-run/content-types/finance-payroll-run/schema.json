{
  "kind": "collectionType",
  "collectionName": "finance_payroll_runs",
  "info": {
    "singularName": "finance-payroll-run",
    "pluralName": "finance-payroll-runs",
    "displayName": "Finance Payroll Run",
    "description": "Monthly payroll workflow"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "workspace_id": { "type": "biginteger", "required": true },
    "period_month": { "type": "string", "required": true },
    "cutoff_date": { "type": "date" },
    "payday_date": { "type": "date", "required": true },
    "status": {
      "type": "enumeration",
      "enum": ["DRAFT", "APPROVED", "PAID"],
      "required": true,
      "default": "DRAFT"
    },
    "approved_by_user_id": { "type": "biginteger" },
    "approved_at": { "type": "datetime" },
    "paid_at": { "type": "datetime" },
    "created_by_user_id": { "type": "biginteger", "required": true }
  }
}
