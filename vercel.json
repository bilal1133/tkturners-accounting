{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd dashboard && yarn install --frozen-lockfile",
  "buildCommand": "cd dashboard && yarn build",
  "outputDirectory": "dashboard/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
