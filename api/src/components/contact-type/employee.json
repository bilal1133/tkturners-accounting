    },
    "position": {
      "type": "string"
    },
    "birth_day": {
      "type": "date"
    },
    "address": {
      "type": "string"
    },
    "cnic": {
      "type": "biginteger"
    },
    "joining_date": {
      "type": "date"
    },
    "bank_account": {
