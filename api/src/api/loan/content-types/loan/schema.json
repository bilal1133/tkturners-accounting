{
  "kind": "collectionType",
  "collectionName": "loans",
  "info": {
    "singularName": "loan",
    "pluralName": "loans",
    "displayName": "Loan"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "total_amount": {
      "type": "decimal",
      "required": true
    },
    "monthly_installment": {
      "type": "decimal",
      "required": true
    },
    "remaining_balance": {
      "type": "decimal",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "default": "Active",
      "enum": [
        "Active",
        "Paid Off",
        "Defaulted"
      ]
    },
    "disbursement_transaction": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::transaction.transaction",
      "inversedBy": "loan_disbursement"
    }
  }
}
